# Copy this file to .env and fill in your values.

# Required for Mapbox basemap rendering
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# true  => show labels/symbols (satellite streets)
# false => imagery-only (no labels/symbols)
VITE_MAP_LABELS=false

# Optional backend HTTP base URL (defaults to http://localhost:8000)
VITE_API_BASE_URL=http://localhost:8000

# Optional explicit WebSocket URL. If omitted, derived from VITE_API_BASE_URL
# (http -> ws, https -> wss) plus /ws/radar.
# VITE_WS_URL=ws://localhost:8000/ws/radar
